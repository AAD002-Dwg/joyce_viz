    },
    {
      "id": "80-bJZUBeQi-aLQfe7F3",
      "title": "Chamber music",
      "color": "#307EE3",
      "tag": "The Writer",
      "snippet": "Chamber music. Could make a kind of pun on that. It is a kind of music I often thought when she. Acoustics that is. Tinkling. Empty vessels make most noise.",
      "order": 89,
      "url": "https://www.joyceproject.com/notes/80-bJZUBeQi-aLQfe7F3"
    },
    {
      "id": "00-bJZUBeQi-aLQfd66b",
